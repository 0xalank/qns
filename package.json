{
  "name": "qns-payment-code",
  "version": "2.0.0",
  "description": "QNNS - Quai Network Name Service with ERC-721, auctions, marketplace, and IPFS content hash",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat compile && node test/run.js",
    "deploy": "node scripts/deploy.js",
    "deploy:examples": "hardhat run scripts/deploy-example-modules.js",
    "deploy:examples:quais": "node scripts/deploy-example-modules-quais.js",
    "deploy:examples:mainnet": "env EXAMPLE_MODULE=fixed-static node scripts/deploy-example-modules-quais.js",
    "deploy:examples:html:mainnet": "env EXAMPLE_MODULE=html-css node scripts/deploy-example-modules-quais.js",
    "deploy:qnns:mainnet": "node scripts/deploy-qnns-mainnet.js",
    "register:qnns:mainnet": "node scripts/register-qnns-name-mainnet.js",
    "publish:static:mainnet": "node scripts/publish-static-site-mainnet.js",
    "anchor:module:mainnet": "node scripts/anchor-module-mainnet.js",
    "anchor:demo-name:mainnet": "node scripts/deploy-demo-name-anchor-mainnet.js",
    "probe:qnns:mainnet": "node scripts/probe-qnns-mainnet.js",
    "load:module:mainnet": "node scripts/load-module-mainnet.js",
    "verify:module:mainnet": "node scripts/verify-module-mainnet.js",
    "check:module-deploy-target": "hardhat run scripts/check-module-deploy-target.js",
    "subgraph:codegen": "graph codegen indexer/subgraph.yaml",
    "subgraph:build": "graph build indexer/subgraph.yaml",
    "subgraph:create": "graph create qns/qnns --node $GRAPH_NODE_ADMIN_URL",
    "subgraph:deploy": "graph deploy qns/qnns --node $GRAPH_NODE_ADMIN_URL --ipfs $GRAPH_IPFS_URL indexer/subgraph.yaml",
    "build": "tsc",
    "clean": "rm -rf dist cache artifacts"
  },
  "keywords": [
    "quai",
    "blockchain",
    "name-service",
    "payment-codes",
    "bip47"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "quais": "^1.0.0-alpha.52"
  },
  "devDependencies": {
    "@graphprotocol/graph-ts": "^0.38.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@quai/hardhat-deploy-metadata": "^1.0.8",
    "@types/node": "^20",
    "hardhat": "^2.26.3",
    "typescript": "^5"
  },
  "files": [
    "dist/sdk/**/*",
    "contracts/**/*",
    "README.md"
  ]
}
