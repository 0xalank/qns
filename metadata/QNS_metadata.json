Heartbeat - prove you're still active\"},\"profiles(bytes32)\":{\"notice\":\"Mapping from name hash to profile\"},\"reclaimInactive(bytes32)\":{\"notice\":\"Reclaim an inactive name (no interaction for 2 years)\"},\"registrationFee()\":{\"notice\":\"Registration fee (500 QUAI)\"},\"release(bytes32)\":{\"notice\":\"Voluntarily release your name\"},\"reserved(bytes32)\":{\"notice\":\"Reserved names (admin-only registration)\"},\"reveal(string,bytes32,address,string)\":{\"notice\":\"Step 2: Reveal and register the name\"},\"setAvatar(bytes32,bytes)\":{\"notice\":\"Set on-chain avatar (max 15KB)\"},\"setNostrPubkey(bytes32,string)\":{\"notice\":\"Update Nostr public key (hex-encoded, 64 chars)\"},\"setProfile(bytes32,string,string,string)\":{\"notice\":\"Update profile text fields\"},\"setQiPaymentCode(bytes32,string)\":{\"notice\":\"Update Qi payment code\"},\"setQuaiAddress(bytes32,address)\":{\"notice\":\"Update Quai address\"},\"setSocials(bytes32,string,string,string,string)\":{\"notice\":\"Update social links\"}},\"notice\":\"Soulbound name registry for Quai Network\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"contracts/QNS.sol\":\"QNS\"},\"evmVersion\":\"paris\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[],\"viaIR\":true},\"sources\":{\"contracts/QNS.sol\":{\"keccak256\":\"0x3598ebcb75f7f875e3c7b5165b7f26409398cbb138c7102e251581fad0bd65de\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://b97a3cc33550174bd164bdfe7b67b1e388201e1086ea49738b5a509c3437ce80\",\"dweb:/ipfs/QmbybdBBWhXFrw7d9eoYzfXXajiH4KURVAkW2guz4AsgM6\"]}},\"version\":1}"